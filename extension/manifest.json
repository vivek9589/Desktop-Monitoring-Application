{
  "manifest_version": 3,
  "name": "Activity Tracker",
  "version": "1.0",
  "description": "Tracks active tab URL and sends to local agent",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": [
    "http://192.168.68.118:9090/*",
    "http://127.0.0.1:9090/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
